# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → Your Project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Resend (Email) ────────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_...
# Must match a verified domain in your Resend account
EMAIL_FROM_DOMAIN=suchithraprints.in

# ── Redis (Upstash — free tier) ───────────────────────────────────────────────
# Get from: https://upstash.com → Create Redis Database → REST Credentials
REDIS_HOST=your-redis-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_TLS=true

# ── Admin Security ────────────────────────────────────────────────────────────
# Choose any strong secret — must match VITE_ADMIN_KEY in the frontend .env
ADMIN_SECRET_KEY=change-this-to-a-strong-secret

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=https://suchithraprints.in
